{
  "openapi": "3.0.3",
  "info": {
    "title": "Arox Profiles API",
    "description": "API for managing profiles and performing Epic Games (Legendary-style) auth, backed by Firebase.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/api/profiles/create": {
      "post": {
        "summary": "Create a profile",
        "description": "Creates a profile document in Firestore. Requires Firebase ID token in Authorization header.",
        "security": [
          {
            "firebaseBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created profile id and data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Profile"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/profiles/delete": {
      "post": {
        "summary": "Delete a profile",
        "description": "Deletes a profile. Requires Firebase ID token in Authorization header.",
        "security": [
          {
            "firebaseBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileDelete"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/profiles/update": {
      "post": {
        "summary": "Update a profile",
        "description": "Update profile fields. Requires Firebase ID token in Authorization header.",
        "security": [
          {
            "firebaseBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Profile"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/profiles/auth/legendary": {
      "post": {
        "summary": "Create Legendary-style auth link",
        "description": "Returns an `arox://auth/<...>` link and the raw Epic auth URL. Requires Firebase ID token.",
        "security": [
          {
            "firebaseBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileAuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "arox link and authUrl",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "arox": {
                      "type": "string"
                    },
                    "authUrl": {
                      "type": "string"
                    },
                    "state": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/profiles/gettokens": {
      "get": {
        "summary": "Fetch stored tokens for a profile (admin)",
        "description": "Returns stored `auth` tokens for a profile. Requires `x-server-key` header.",
        "parameters": [
          {
            "name": "account-uid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "profile-id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Auth tokens",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "auth": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/profiles/auth/epic/callback": {
      "get": {
        "summary": "Epic OAuth callback",
        "description": "Endpoint that Epic redirects to with `code` and `state`. Exchanges code for tokens and stores them.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Human readable success message",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "firebaseBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "serverKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-server-key"
      }
    },
    "schemas": {
      "ProfileCreate": {
        "type": "object",
        "required": ["name", "account-uid"],
        "properties": {
          "name": {
            "type": "string"
          },
          "avatar-url": {
            "type": "string"
          },
          "account-uid": {
            "type": "string"
          },
          "pin": {
            "type": "string",
            "description": "4 digit numeric PIN (optional)"
          }
        }
      },
      "ProfileDelete": {
        "type": "object",
        "required": ["account-uid", "profile-id"],
        "properties": {
          "account-uid": {
            "type": "string"
          },
          "profile-id": {
            "type": "string"
          }
        }
      },
      "ProfileUpdate": {
        "type": "object",
        "required": ["account-uid", "profile-id"],
        "properties": {
          "account-uid": {
            "type": "string"
          },
          "profile-id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "avatar-url": {
            "type": "string"
          },
          "pin": {
            "type": "string"
          }
        }
      },
      "ProfileAuthRequest": {
        "type": "object",
        "required": ["account-uid", "profile-id"],
        "properties": {
          "account-uid": {
            "type": "string"
          },
          "profile-id": {
            "type": "string"
          }
        }
      },
      "Profile": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "accountUid": {
            "type": "string"
          },
          "pin": {
            "type": "string"
          },
          "uid": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        }
      },
      "responses": {
        "BadRequest": {
          "description": "Bad Request",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "error": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "Unauthorized": {
          "description": "Unauthorized",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "error": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "Forbidden": {
          "description": "Forbidden",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "error": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "NotFound": {
          "description": "Not Found",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "error": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "InternalError": {
          "description": "Internal Server Error",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "error": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "firebaseBearer": []
    }
  ]
}
